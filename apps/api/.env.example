NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,https://<vercel-project>.vercel.app

# DEV (mặc định): SQLite, không cần cài gì
DATABASE_URL="file:./dev.db"

# PRODUCTION: Postgres (Render/Neon). Khi deploy:
# 1. Đổi provider trong prisma/schema.prisma từ "sqlite" sang "postgresql"
# 2. Dán connection string Postgres vào đây
# DATABASE_URL=postgresql://user:pass@host:5432/eurohouse?schema=public

REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
DEMO_ADMIN_EMAIL=board@eurohouse.vn
DEMO_ADMIN_PASSWORD=Eurohouse@2026
